---
// Side-by-side proof for the "Context Crafter" challenge: the custom
// copilot-instructions.md rules (left) vs. the GameOver UI that Copilot
// generated by following them (right). Every rule maps to something visible.
import GameOver from "../components/GameOver.astro";

const rules: { rule: string; token: string }[] = [
  { rule: "CSS grid for all layout", token: "display: grid" },
  { rule: "Primary button = neon magenta", token: "#FF00FF" },
  { rule: 'Font "Press Start 2P", UPPERCASE headings', token: "Press Start 2P" },
  { rule: "Neon glow on headings", token: "text-shadow: 0 0 …" },
  { rule: "CRT scanline overlay", token: ".crt-screen::after" },
  { rule: "Retro sfx code comments", token: "// 🔊 sfx:" },
  { rule: "Arcade-announcer copy", token: "GAME OVER / INSERT COIN" },
  { rule: "Respects reduced motion", token: "@media reduce" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Mona Mayhem — Context vs UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header><h1>CONTEXT ENGINEERING &mdash; instructions in, UI out</h1></header>
    <div class="split">
      <aside class="rules">
        <h2>.github/copilot-instructions.md</h2>
        <ul>
          {rules.map((r) => (
            <li><span class="check">✓</span><span>{r.rule} <code>{r.token}</code></span></li>
          ))}
        </ul>
        <p class="caption">Every rule on the left is honored by the generated screen on the right →</p>
      </aside>
      <div class="preview"><GameOver winner="TORVALDS" loser="OCTOCAT" rounds={15} /></div>
    </div>

    <style>
      body {
        margin: 0;
        font-family: "Press Start 2P", ui-monospace, monospace;
        background: #0d0221;
        color: #e6e6fa;
      }
      header { text-align: center; padding: 22px 16px 6px; }
      header h1 { color: #00ffff; font-size: 0.95rem; text-shadow: 0 0 8px #00ffff88; }
      .split {
        display: grid;                          /* grid, per the rules */
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        padding: 16px;
        align-items: stretch;
      }
      .rules {
        background: #160a33;
        border: 2px solid #00ffff;
        box-shadow: 0 0 14px #00ffff55;
        border-radius: 10px;
        padding: 22px;
      }
      .rules h2 { color: #ff00ff; font-size: 0.8rem; margin: 0 0 18px; text-shadow: 0 0 6px #ff00ff88; }
      .rules ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 14px; }
      .rules li { display: grid; grid-template-columns: auto 1fr; gap: 10px; font-size: 0.62rem; line-height: 1.7; }
      .check { color: #39ff14; text-shadow: 0 0 6px #39ff14; }
      code { color: #00ffff; font-size: 0.58rem; }
      .caption { margin-top: 20px; color: #b8a9ff; font-size: 0.55rem; line-height: 1.7; }
      .preview { border-radius: 10px; overflow: hidden; min-height: 540px; display: grid; }
    </style>
  </body>
</html>
